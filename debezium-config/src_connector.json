{
  "name": "src_connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.dbname": "cdc_db",
    "database.hostname": "postgres",
    "database.password": "debezium",
    "database.port": "5432",
    "database.server.name": "workitems",
    "database.user": "debezium",
    "decimal.handling.mode": "string",
    "heartbeat.interval.ms": "10000",
    "heartbeat.topics.prefix": "heartbeat",
    "include.schema.changes": "false",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "max.batch.size": "2048",
    "max.queue.size": "8192",
    "plugin.name": "pgoutput",
    "poll.interval.ms": "1000",
    "publication.name": "debezium_workitems_pub",
    "slot.drop.on.stop": "false",
    "slot.name": "debezium_workitems_slot",
    "snapshot.fetch.size": "10000",
    "snapshot.mode": "initial",
    "table.include.list": "public.user_item_projection",
    "time.precision.mode": "connect",
    "tombstones.on.delete": "true",
    "topic.prefix": "cdc",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "transforms": "unwrap",
    "transforms.unwrap.add.fields": "op,ts_ms,transaction.id,transaction.total_order,transaction.data_collection_order,source.table,source.db,source.ts_ms",
    "transforms.unwrap.add.fields.prefix": "__",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "provide.transaction.metadata": "true"
  }
}